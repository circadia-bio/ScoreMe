{
  "expo": {
    "name": "ScoreMe",
    "slug": "scoreme",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#C8DFF5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.circadia.scoreme"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#C8DFF5"
      },
      "package": "com.circadia.scoreme"
    },
    "scheme": "scoreme",
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon-1024.png",
      "name": "ScoreMe",
      "shortName": "ScoreMe",
      "description": "Research questionnaire scorer · Circadia Lab",
      "themeColor": "#4A7BB5",
      "backgroundColor": "#EEF5FF",
      "title": "ScoreMe"
    }
  }
}
